---
import Layout from '../../layouts/Layout.astro';
---

<Layout title="Strapi-like Component Builder">
    <div class="flex-1 p-6">
        <div class="grid grid-cols-1 lg:grid-cols-12 gap-6">
          
          <!-- Left: Field Configurator (7 Columns) -->
          <section class="lg:col-span-7 bg-white rounded-xl border border-slate-200 shadow-xs flex flex-col h-[calc(100vh-140px)]">
            <div class="p-4 border-b border-slate-200 flex justify-between items-center bg-slate-50/50 rounded-t-xl">
              <h2 class="font-semibold text-slate-700 flex items-center gap-2">
                <i data-lucide="sliders" class="w-4 h-4 text-slate-500"></i> Fields Configuration
              </h2>
              <button onclick="openAddFieldModal()" class="text-indigo-600 hover:text-indigo-700 bg-indigo-50 hover:bg-indigo-100 text-xs font-semibold px-3 py-1.5 rounded-md transition flex items-center gap-1 cursor-pointer">
                <i data-lucide="plus" class="w-3.5 h-3.5"></i> Add Field
              </button>
            </div>

            <!-- Fields List Area -->
            <div id="fieldsContainer" class="p-6 overflow-y-auto flex-1 space-y-4">
              <!-- Empty State -->
              <div id="emptyState" class="text-center py-12 flex flex-col items-center justify-center border-2 border-dashed border-slate-200 rounded-xl p-6">
                <div class="bg-slate-100 p-3 rounded-full text-slate-400 mb-3">
                  <i data-lucide="code-2" class="w-6 h-6"></i>
                </div>
                <p class="text-sm font-medium text-slate-600">No fields added yet</p>
                <p class="text-xs text-slate-400 mt-1 max-w-xs">Click "Add Field" to start building your dynamic component structure.</p>
              </div>
            </div>
          </section>

          <!-- Right: Live Preview & JSON Schema (5 Columns) -->
          <section class="lg:col-span-5 flex flex-col gap-6 h-[calc(100vh-140px)]">
            
            <!-- Live Preview Box -->
            <div class="bg-white rounded-xl border border-slate-200 shadow-xs flex flex-col flex-1 overflow-hidden">
              <div class="p-4 border-b border-slate-200 bg-slate-50/50">
                <h2 class="font-semibold text-slate-700 flex items-center gap-2">
                  <i data-lucide="eye" class="w-4 h-4 text-slate-500"></i> Live Component Preview
                </h2>
              </div>
              <div class="p-6 overflow-y-auto flex-1 bg-slate-50/30">
                <form id="previewForm" onsubmit="event.preventDefault();" class="space-y-4 bg-white p-6 rounded-lg border border-slate-200 shadow-xs">
                  <!-- Rendered fields go here -->
                  <div id="previewContainer" class="space-y-4"></div>
                  <button type="submit" id="previewSubmitBtn" class="w-full bg-slate-800 text-white text-sm font-medium py-2 rounded-lg mt-4 opacity-50 cursor-not-allowed" disabled>
                    Submit Form
                  </button>
                </form>
              </div>
            </div>

            <!-- Schema Output Box -->
            <div class="bg-slate-900 rounded-xl border border-slate-800 shadow-md h-48 flex flex-col overflow-hidden">
              <div class="px-4 py-2.5 bg-slate-950 border-b border-slate-800 flex justify-between items-center">
                <span class="text-xs font-mono font-semibold text-slate-400">Generated Schema JSON</span>
                <button onclick="copySchema()" class="text-slate-400 hover:text-white text-xs flex items-center gap-1 transition cursor-pointer">
                  <i data-lucide="copy" class="w-3 h-3"></i> Copy
                </button>
              </div>
              <pre class="p-4 overflow-auto flex-1 text-xs font-mono text-emerald-400 bg-slate-900/50"><code id="schemaJson">[]</code></pre>
            </div>
          </section>
        </div>
    </div>

    <!-- Add/Edit Field Modal -->
    <div id="fieldModal" class="fixed inset-0 bg-slate-900/40 backdrop-blur-xs hidden items-center justify-center z-50 p-4 animate-fade-in">
      <div class="bg-white rounded-xl border border-slate-200 w-full max-w-md shadow-xl flex flex-col max-h-[90vh] animate-slide-up">
        <div class="p-4 border-b border-slate-200 flex justify-between items-center bg-slate-50 rounded-t-xl">
          <h3 id="modalTitle" class="font-bold text-slate-800">Add New Field</h3>
          <button onclick="closeFieldModal()" class="text-slate-400 hover:text-slate-600 rounded-lg p-1 transition cursor-pointer">
            <i data-lucide="x" class="w-5 h-5"></i>
          </button>
        </div>
        
        <form id="fieldForm" onsubmit="saveField(event)" class="p-6 overflow-y-auto space-y-4 flex-1">
          <input type="hidden" id="fieldId">
          
          <!-- Field Type Selection -->
          <div>
            <label class="block text-xs font-semibold text-slate-600 uppercase tracking-wider mb-1.5">Field Type</label>
            <select id="fieldType" onchange="toggleFieldSpecificOptions()" class="w-full bg-white border border-slate-200 rounded-lg px-3 py-2 text-sm focus:outline-hidden focus:border-indigo-500 focus:ring-2 focus:ring-indigo-100 transition">
              <option value="text">Text Input</option>
              <option value="textarea">Textarea (Long Text)</option>
              <option value="number">Number</option>
              <option value="image">Image Attachment</option>
              <option value="richtext">HTML / Rich Text Preview</option>
            </select>
          </div>

          <!-- Field Label / Title -->
          <div>
            <label class="block text-xs font-semibold text-slate-600 uppercase tracking-wider mb-1.5">Field Label (Title)</label>
            <input type="text" id="fieldLabel" required placeholder="e.g., Product Name, Cover Image" class="w-full border border-slate-200 rounded-lg px-3 py-2 text-sm focus:outline-hidden focus:border-indigo-500 focus:ring-2 focus:ring-indigo-100 transition">
          </div>

          <!-- Field Unique API Key / Name -->
          <div>
            <label class="block text-xs font-semibold text-slate-600 uppercase tracking-wider mb-1.5">API Field Name (Unique key)</label>
            <input type="text" id="fieldName" required placeholder="e.g., product_name, cover_img" class="w-full border border-slate-200 rounded-lg px-3 py-2 text-sm font-mono text-xs focus:outline-hidden focus:border-indigo-500 focus:ring-2 focus:ring-indigo-100 transition">
          </div>

          <!-- Placeholder (Conditional) -->
          <div id="placeholderWrapper">
            <label class="block text-xs font-semibold text-slate-600 uppercase tracking-wider mb-1.5">Placeholder</label>
            <input type="text" id="fieldPlaceholder" placeholder="e.g., Enter product name here..." class="w-full border border-slate-200 rounded-lg px-3 py-2 text-sm focus:outline-hidden focus:border-indigo-500 focus:ring-2 focus:ring-indigo-100 transition">
          </div>

          <!-- Custom HTML Content (Conditional for HTML type) -->
          <div id="htmlContentWrapper" class="hidden">
            <label class="block text-xs font-semibold text-slate-600 uppercase tracking-wider mb-1.5">Raw HTML Raw / Embed Content</label>
            <textarea id="fieldHtmlContent" placeholder="<div class='p-3 bg-amber-50 text-amber-700 text-xs rounded'>Warning box</div>" rows="3" class="w-full border border-slate-200 rounded-lg px-3 py-2 text-sm font-mono text-xs focus:outline-hidden focus:border-indigo-500 focus:ring-2 focus:ring-indigo-100 transition"></textarea>
          </div>

          <!-- Validation Rules -->
          <div class="pt-2 border-t border-slate-100 space-y-3">
            <label class="block text-xs font-semibold text-slate-600 uppercase tracking-wider">Validation Rules</label>
            <label class="flex items-center gap-2.5 text-sm text-slate-700 cursor-pointer select-none">
              <input type="checkbox" id="fieldRequired" class="w-4 h-4 rounded border-slate-300 text-indigo-600 focus:ring-indigo-500 transition">
              <span>Mark as Required field</span>
            </label>
          </div>

          <!-- Action Buttons -->
          <div class="pt-4 border-t border-slate-100 flex justify-end gap-2">
            <button type="button" onclick="closeFieldModal()" class="px-4 py-2 text-sm font-medium text-slate-600 hover:bg-slate-100 rounded-lg transition cursor-pointer">Cancel</button>
            <button type="submit" class="px-4 py-2 text-sm font-medium text-white bg-indigo-600 hover:bg-indigo-700 rounded-lg transition shadow-xs cursor-pointer">Save Field</button>
          </div>
        </form>
      </div>
    </div>

    <script>
      // State Management
      let fields: any[] = [];

      // Initialize Lucide Icons
      document.addEventListener("DOMContentLoaded", () => {
        if (typeof (window as any).lucide !== 'undefined') {
          (window as any).lucide.createIcons();
        }
        updateUI();
      });

      // Modal Handlers
      function openAddFieldModal() {
        const fieldForm = document.getElementById('fieldForm') as HTMLFormElement;
        const fieldId = document.getElementById('fieldId') as HTMLInputElement;
        const modalTitle = document.getElementById('modalTitle');
        if (fieldForm) fieldForm.reset();
        if (fieldId) fieldId.value = '';
        if (modalTitle) modalTitle.innerText = 'Add New Field';
        toggleFieldSpecificOptions();
        toggleModal(true);
      }

      function openEditFieldModal(id: string) {
        const field = fields.find(f => f.id === id);
        if (!field) return;

        const fieldId = document.getElementById('fieldId') as HTMLInputElement;
        const fieldType = document.getElementById('fieldType') as HTMLSelectElement;
        const fieldLabel = document.getElementById('fieldLabel') as HTMLInputElement;
        const fieldName = document.getElementById('fieldName') as HTMLInputElement;
        const fieldPlaceholder = document.getElementById('fieldPlaceholder') as HTMLInputElement;
        const fieldHtmlContent = document.getElementById('fieldHtmlContent') as HTMLTextAreaElement;
        const fieldRequired = document.getElementById('fieldRequired') as HTMLInputElement;
        const modalTitle = document.getElementById('modalTitle');

        if (fieldId) fieldId.value = field.id;
        if (fieldType) fieldType.value = field.type;
        if (fieldLabel) fieldLabel.value = field.label;
        if (fieldName) fieldName.value = field.name;
        if (fieldPlaceholder) fieldPlaceholder.value = field.placeholder || '';
        if (fieldHtmlContent) fieldHtmlContent.value = field.htmlContent || '';
        if (fieldRequired) fieldRequired.checked = field.required;
        if (modalTitle) modalTitle.innerText = 'Edit Field Rules';
        toggleFieldSpecificOptions();
        toggleModal(true);
      }

      function closeFieldModal() {
        toggleModal(false);
      }

      function toggleModal(show: boolean) {
        const modal = document.getElementById('fieldModal');
        if (!modal) return;
        if (show) {
          modal.classList.remove('hidden');
          modal.classList.add('flex');
        } else {
          modal.classList.remove('flex');
          modal.classList.add('hidden');
        }
      }

      function toggleFieldSpecificOptions() {
        const fieldType = document.getElementById('fieldType') as HTMLSelectElement;
        const placeholderWrapper = document.getElementById('placeholderWrapper');
        const htmlContentWrapper = document.getElementById('htmlContentWrapper');
        if (!fieldType || !placeholderWrapper || !htmlContentWrapper) return;

        const type = fieldType.value;
        // Hide or show based on type select choices
        if (type === 'richtext') {
          placeholderWrapper.classList.add('hidden');
          htmlContentWrapper.classList.remove('hidden');
        } else if (type === 'image') {
          placeholderWrapper.classList.add('hidden');
          htmlContentWrapper.classList.add('hidden');
        } else {
          placeholderWrapper.classList.remove('hidden');
          htmlContentWrapper.classList.add('hidden');
        }
      }

      // Save/Update Field Data Orchestration
      function saveField(e: Event) {
        e.preventDefault();
        
        const fieldId = document.getElementById('fieldId') as HTMLInputElement;
        const fieldType = document.getElementById('fieldType') as HTMLSelectElement;
        const fieldLabel = document.getElementById('fieldLabel') as HTMLInputElement;
        const fieldName = document.getElementById('fieldName') as HTMLInputElement;
        const fieldPlaceholder = document.getElementById('fieldPlaceholder') as HTMLInputElement;
        const fieldHtmlContent = document.getElementById('fieldHtmlContent') as HTMLTextAreaElement;
        const fieldRequired = document.getElementById('fieldRequired') as HTMLInputElement;

        const id = fieldId?.value || '';
        const type = fieldType?.value || '';
        const label = fieldLabel?.value.trim() || '';
        const name = fieldName?.value.trim().replace(/\s+/g, '_').toLowerCase() || '';
        const placeholder = fieldPlaceholder?.value.trim() || '';
        const htmlContent = fieldHtmlContent?.value.trim() || '';
        const required = fieldRequired?.checked || false;

        const fieldData = { id: id || Date.now().toString(), type, label, name, placeholder, htmlContent, required };

        if (id) {
          // Update operational step
          fields = fields.map(f => f.id === id ? fieldData : f);
        } else {
          // Insert step
          fields.push(fieldData);
        }

        closeFieldModal();
        updateUI();
      }

      function deleteField(id: string) {
        fields = fields.filter(f => f.id !== id);
        updateUI();
      }

      // UI Synchronizer Loop
      function updateUI() {
        renderConfiguratorList();
        renderLivePreview();
        renderSchemaJSON();
        if (typeof (window as any).lucide !== 'undefined') {
          (window as any).lucide.createIcons();
        }
      }

      // Render Left Configurator Cards
      function renderConfiguratorList() {
        const container = document.getElementById('fieldsContainer');
        const emptyState = document.getElementById('emptyState');
        if (!container || !emptyState) return;
        
        // Clear previous list elements but preserve empty state block layout reference
        const cards = container.querySelectorAll('.field-card');
        cards.forEach(card => card.remove());

        if (fields.length === 0) {
          emptyState.classList.remove('hidden');
          return;
        }
        emptyState.classList.add('hidden');

        fields.forEach((field) => {
          const div = document.createElement('div');
          div.className = 'field-card bg-slate-50 border border-slate-200 rounded-lg p-4 flex justify-between items-center hover:border-slate-300 transition group';
          div.innerHTML = `
            <div class="flex items-center gap-3">
              <div class="bg-white p-2 rounded-md border border-slate-200 text-slate-500 shadow-2xs">
                ${getTypeIcon(field.type)}
              </div>
              <div>
                <div class="flex items-center gap-2">
                  <span class="text-sm font-semibold text-slate-800">${escapeHtml(field.label)}</span>
                  ${field.required ? '<span class="bg-rose-50 text-rose-600 text-[10px] px-1.5 py-0.5 rounded font-medium border border-rose-100">Required</span>' : ''}
                </div>
                <div class="flex items-center gap-1.5 mt-0.5">
                  <span class="text-xs font-mono text-slate-400">${escapeHtml(field.name)}</span>
                  <span class="text-slate-300 text-xs">•</span>
                  <span class="text-xs text-slate-500 capitalize">${field.type}</span>
                </div>
              </div>
            </div>
            <div class="flex items-center gap-1 opacity-80 group-hover:opacity-100 transition">
              <button onclick="openEditFieldModal('${field.id}')" class="p-1.5 text-slate-500 hover:text-indigo-600 hover:bg-white rounded-md border border-transparent hover:border-slate-200 transition cursor-pointer">
                <i data-lucide="settings-2" class="w-4 h-4"></i>
              </button>
              <button onclick="deleteField('${field.id}')" class="p-1.5 text-slate-500 hover:text-rose-600 hover:bg-white rounded-md border border-transparent hover:border-slate-200 transition cursor-pointer">
                <i data-lucide="trash-2" class="w-4 h-4"></i>
              </button>
            </div>
          `;
          container.appendChild(div);
        });
      }

      // Render Right Preview Elements Dynamic Forms
      function renderLivePreview() {
        const container = document.getElementById('previewContainer');
        const submitBtn = document.getElementById('previewSubmitBtn') as HTMLButtonElement;
        if (!container || !submitBtn) return;
        container.innerHTML = '';

        if (fields.length === 0) {
          container.innerHTML = `<p class="text-slate-400 text-xs text-center py-6">Your layout engine preview will render interactively right here.</p>`;
          submitBtn.className = "w-full bg-slate-800 text-white text-sm font-medium py-2 rounded-lg mt-4 opacity-40 cursor-not-allowed";
          submitBtn.disabled = true;
          return;
        }

        submitBtn.className = "w-full bg-indigo-600 hover:bg-indigo-700 text-white text-sm font-medium py-2 rounded-lg mt-4 transition cursor-pointer shadow-xs";
        submitBtn.disabled = false;

        fields.forEach((field) => {
          const formGroup = document.createElement('div');
          formGroup.className = 'space-y-1.5';

          const labelHtml = `<label class="block text-xs font-semibold text-slate-700">${escapeHtml(field.label)} ${field.required ? '<span class="text-rose-500">*</span>' : ''}</label>`;
          
          let inputHtml = '';
          const reqAttr = field.required ? 'required' : '';

          switch (field.type) {
            case 'text':
              inputHtml = `<input type="text" name="${field.name}" placeholder="${escapeHtml(field.placeholder)}" ${reqAttr} class="w-full border border-slate-200 rounded-lg px-3 py-2 text-sm bg-slate-50/50 focus:bg-white focus:outline-hidden focus:border-indigo-500 focus:ring-2 focus:ring-indigo-100 transition">`;
              break;
            case 'textarea':
              inputHtml = `<textarea name="${field.name}" placeholder="${escapeHtml(field.placeholder)}" rows="3" ${reqAttr} class="w-full border border-slate-200 rounded-lg px-3 py-2 text-sm bg-slate-50/50 focus:bg-white focus:outline-hidden focus:border-indigo-500 focus:ring-2 focus:ring-indigo-100 transition"></textarea>`;
              break;
            case 'number':
              inputHtml = `<input type="number" name="${field.name}" placeholder="${escapeHtml(field.placeholder)}" ${reqAttr} class="w-full border border-slate-200 rounded-lg px-3 py-2 text-sm bg-slate-50/50 focus:bg-white focus:outline-hidden focus:border-indigo-500 focus:ring-2 focus:ring-indigo-100 transition">`;
              break;
            case 'image':
              inputHtml = `
                <div class="border border-dashed border-slate-200 rounded-lg p-4 bg-slate-50/30 text-center hover:bg-slate-50 transition relative">
                  <input type="file" accept="image/*" name="${field.name}" ${reqAttr} class="absolute inset-0 opacity-0 cursor-pointer w-full h-full">
                  <i data-lucide="image-plus" class="w-5 h-5 text-slate-400 mx-auto mb-1.5"></i>
                  <span class="block text-xs text-slate-500 font-medium">Click to upload or drag image image assets</span>
                </div>`;
              break;
            case 'richtext':
              // Renders standard safe template strings injection for modular blocks injection rules
              inputHtml = `<div class="p-3 border border-slate-200 bg-slate-50/30 rounded-lg text-xs overflow-x-auto">${field.htmlContent || '<span class="text-slate-400 italic">No HTML content provided</span>'}</div>`;
              break;
          }

          formGroup.innerHTML = labelHtml + inputHtml;
          container.appendChild(formGroup);
        });
        if (typeof (window as any).lucide !== 'undefined') {
          (window as any).lucide.createIcons();
        }
      }

      function renderSchemaJSON() {
        // Remove structural UI random unique hash generated tracking properties on view output
        const cleanSchema = fields.map(({id, ...rest}) => rest);
        const schemaJson = document.getElementById('schemaJson');
        if (schemaJson) schemaJson.innerText = JSON.stringify(cleanSchema, null, 2);
      }

      // Helper utilities
      function getTypeIcon(type: string) {
        switch(type) {
          case 'text': return '<i data-lucide="type" class="w-4 h-4"></i>';
          case 'textarea': return '<i data-lucide="align-left" class="w-4 h-4"></i>';
          case 'number': return '<i data-lucide="binary" class="w-4 h-4"></i>';
          case 'image': return '<i data-lucide="image" class="w-4 h-4"></i>';
          case 'richtext': return '<i data-lucide="file-code" class="w-4 h-4"></i>';
          default: return '<i data-lucide="help-circle" class="w-4 h-4"></i>';
        }
      }

      function escapeHtml(str: string) {
        if (!str) return '';
        return str.replace(/&/g, "&amp;").replace(/</g, "&lt;").replace(/>/g, "&gt;").replace(/"/g, "&quot;").replace(/'/g, "&#039;");
      }

      function copySchema() {
        const schemaJson = document.getElementById('schemaJson');
        if (!schemaJson) return;
        const jsonText = schemaJson.innerText;
        navigator.clipboard.writeText(jsonText).then(() => {
          alert('Schema successfully copied to clipboard!');
        });
      }

      function exportSchema() {
        const cleanSchema = fields.map(({id, ...rest}) => rest);
        const dataStr = "data:text/json;charset=utf-8," + encodeURIComponent(JSON.stringify(cleanSchema, null, 2));
        const downloadAnchor = document.createElement('a');
        downloadAnchor.setAttribute("href", dataStr);
        downloadAnchor.setAttribute("download", "component-schema.json");
        document.body.appendChild(downloadAnchor);
        downloadAnchor.click();
        downloadAnchor.remove();
      }
    </script>
</Layout>
