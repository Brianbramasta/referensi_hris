<!DOCTYPE html>
<html lang="id">
<head>
  <meta charset="UTF-8">
  <meta name="viewport" content="width=device-width, initial-scale=1.0">
  <title>Hero Section with Scroll Parallax Shapes</title>
  <!-- Tailwind CSS CDN -->
  <style>
    /* Custom font & smooth scroll */
    html {
      scroll-behavior: smooth;
    }
  </style>
</head>
<body class="bg-slate-900 text-white font-sans antialiased">

  <!-- HERO SECTION CONTAINER -->
  <header class="relative min-h-screen w-full overflow-hidden flex flex-col justify-between bg-gradient-to-b from-[#0b3c5d] via-[#0d5c8a] to-[#0f71a9]">
    
    <!-- BACKGROUND OVERLAY (IMAGE / PATTERN) -->
    <div class="absolute inset-0 z-0 opacity-20 pointer-events-none bg-cover bg-center" style="background-image: url('https://images.unsplash.com/photo-1522071820081-009f0129c71c?auto=format&fit=crop&w=1600&q=80');">
    </div>

    <!-- NAVBAR -->
    <nav class="relative z-20 flex items-center justify-between px-8 py-6 max-w-7xl w-full mx-auto">
      <!-- Logo -->
      <div class="flex items-center gap-2">
        <div class="w-9 h-9 rounded-full bg-gradient-to-tr from-orange-500 to-blue-400 p-[3px]">
          <div class="w-full h-full bg-[#0b3c5d] rounded-full flex items-center justify-center">
            <span class="text-xs font-bold text-orange-400">●</span>
          </div>
        </div>
      </div>

      <!-- Menu Items -->
      <ul class="hidden md:flex items-center gap-8 text-sm font-medium text-slate-200">
        <li><a href="#" class="hover:text-orange-400 transition">Beranda</a></li>
        <li><a href="#" class="hover:text-orange-400 transition">Tentang kami</a></li>
        <li><a href="#" class="hover:text-orange-400 transition">Perusahaan</a></li>
        <li><a href="#" class="hover:text-orange-400 transition">Artikel</a></li>
        <li><a href="#" class="hover:text-orange-400 transition">Karir</a></li>
      </ul>

      <!-- Login Button -->
      <div>
        <a href="#" class="inline-flex items-center gap-2 bg-orange-500 hover:bg-orange-600 text-white text-sm font-semibold px-5 py-2.5 rounded-lg shadow-lg transition duration-200">
          <svg class="w-4 h-4" fill="none" stroke="currentColor" viewBox="0 0 24 24">
            <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M16 7a4 4 0 11-8 0 4 4 0 018 0zM12 14a7 7 0 00-7 7h14a7 7 0 00-7-7z"/>
          </svg>
          Login
        </a>
      </div>
    </nav>

    <!-- FLOATING SCROLL DECORATIONS (JAJAR GENJANG / BELAH KETUPAT) -->
    <!-- Shape 1: Kiri Besar (Biru) -->
    <div id="shape-left-blue" 
         class="parallax-shape absolute -left-20 top-1/3 w-64 h-64 bg-blue-500/80 rounded-3xl rotate-45 -skew-x-12 blur-sm pointer-events-none z-10 transition-transform duration-75 ease-out">
    </div>

    <!-- Shape 2: Kiri Atas (Orange Glowing) -->
    <div id="shape-left-orange" 
         class="parallax-shape absolute left-12 md:left-44 top-1/4 w-28 h-28 bg-gradient-to-tr from-orange-500 to-amber-400 rounded-2xl rotate-45 skew-y-6 shadow-2xl shadow-orange-500/50 blur-[1px] pointer-events-none z-10 transition-transform duration-75 ease-out">
    </div>

    <!-- Shape 3: Kanan Bawah (Orange) -->
    <div id="shape-right-orange" 
         class="parallax-shape absolute right-8 md:right-32 bottom-1/4 w-32 h-32 bg-gradient-to-br from-orange-500 to-orange-600 rounded-2xl rotate-45 -skew-x-6 shadow-xl shadow-orange-500/40 pointer-events-none z-10 transition-transform duration-75 ease-out">
    </div>

    <!-- Shape 4: Kanan Background (Biru Soft) -->
    <div id="shape-right-blue" 
         class="parallax-shape absolute -right-16 top-1/2 w-72 h-72 bg-sky-400/40 rounded-3xl rotate-45 blur-md pointer-events-none z-0 transition-transform duration-75 ease-out">
    </div>

    <!-- MAIN HERO CONTENT -->
    <div class="relative z-20 my-auto text-center px-4 max-w-5xl mx-auto">
      <h1 class="text-4xl sm:text-6xl md:text-7xl font-bold tracking-tight text-white leading-tight drop-shadow-md">
        Kinship, Integrity<br>
        Teamwork, Authenticity
      </h1>
    </div>

    <!-- BOTTOM WAVE OVERLAY -->
    <div class="relative z-10 w-full overflow-hidden leading-none">
      <div class="w-full h-24 bg-gradient-to-t from-sky-950/80 to-transparent"></div>
    </div>

  </header>

  <!-- DUMMY CONTENT SECTION (UNTUK MERASAKAN EFEK SCROLL) -->
  <section class="min-h-screen bg-slate-950 px-8 py-20 max-w-6xl mx-auto">
    <h2 class="text-3xl font-bold text-center mb-8 text-sky-400">Scroll Ke Bawah / Atas</h2>
    <p class="text-slate-400 text-center max-w-2xl mx-auto leading-relaxed">
      Perhatikan elemen jajar genjang / belah ketupat di header di atas. Masing-masing elemen bergerak dengan kecepatan dan arah yang berbeda (parallax effect) sesuai scroll posisi harian Anda.
    </p>
  </section>

  <!-- PARALLAX SCROLL SCRIPT -->
  <script>
    document.addEventListener('DOMContentLoaded', () => {
      const shapeLeftBlue = document.getElementById('shape-left-blue');
      const shapeLeftOrange = document.getElementById('shape-left-orange');
      const shapeRightOrange = document.getElementById('shape-right-orange');
      const shapeRightBlue = document.getElementById('shape-right-blue');

      window.addEventListener('scroll', () => {
        const scrolled = window.scrollY;

        // Atur kecepatan dan arah pergerakan bentuk geometris
        if (shapeLeftBlue) {
          shapeLeftBlue.style.transform = `translateY(${scrolled * 0.25}px) rotate(45deg) skewX(-12deg)`;
        }
        if (shapeLeftOrange) {
          shapeLeftOrange.style.transform = `translateY(${scrolled * -0.35}px) rotate(${45 + scrolled * 0.05}deg) skewY(6deg)`;
        }
        if (shapeRightOrange) {
          shapeRightOrange.style.transform = `translateY(${scrolled * -0.2}px) rotate(${45 - scrolled * 0.03}deg) skewX(-6deg)`;
        }
        if (shapeRightBlue) {
          shapeRightBlue.style.transform = `translateY(${scrolled * 0.4}px) rotate(45deg)`;
        }
      });
    });
  </script>
</body>
</html>