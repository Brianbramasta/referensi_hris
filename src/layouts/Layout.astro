---
import '../styles/global.css';
import Sidebar from '../components/Sidebar.astro';

interface Props {
  title?: string;
}

const { title = 'HRIS Hub' } = Astro.props;
---

<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>{title}</title>
    <!-- Lucide Icons -->
    <script src="https://unpkg.com/lucide@latest"></script>
</head>
<body class="bg-[#FBFBFA] text-[#37352F] antialiased min-h-screen flex">
    
    <Sidebar />
    
    <!-- Main Content -->
    <div class="flex-1 flex flex-col">
        <!-- Header -->
        <header class="border-b border-[#EDECE9] bg-white sticky top-0 z-50">
            <div class="px-6 h-16 flex items-center justify-between">
                <nav class="flex items-center space-x-6 text-sm font-medium text-[#787774]">
                    <a href="/" class="text-[#37352F] hover:text-black transition">Overview</a>
                    <a href="#" class="hover:text-black transition">Docs</a>
                    <span class="h-4 w-px bg-[#EDECE9]"></span>
                    <span class="text-xs bg-[#F1F1EF] text-[#37352F] px-2 py-1 rounded border border-[#EDECE9]">v1.0.0</span>
                </nav>
            </div>
        </header>

        <main class="flex-1">
            <slot />
        </main>
    </div>

    <script>
        import { renderSidebar } from '../js/sidebar-config';
        document.addEventListener('DOMContentLoaded', renderSidebar);
    </script>
</body>
</html>
